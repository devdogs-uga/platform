{
  "name": "DevDogs-Website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm run lint:fix && pnpm run typecheck && pnpm run prettier",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "sb:seed": "dotenv -v next_public_avatars_bucket=$NEXT_PUBLIC_AVATARS_BUCKET -- supabase seed buckets --yes",
    "sb:start": "dotenv -- supabase start && supabase status -o env > .env.local && dotenv -- pnpm sb:seed",
    "sb:stop": "supabase stop",
    "sb:restart": "pnpm sb:stop && pnpm sb:start",
    "dev": "pnpm sb:start && pnpm db:push && pnpm next dev",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "prettier": "prettier -w .",
    "prettier:check": "prettier -c .",
    "preview": "next build && next start",
    "start": "next start",
    "sync-upstream": "git fetch && git branch | grep -Po '\\Kfeature/.*' | xargs -i sh -c 'git checkout {} && git pull upstream main && git push upstream {}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@discordjs/builders": "^1.14.1",
    "@discordjs/rest": "^2.6.1",
    "@octokit/graphql": "^9.0.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.2",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "discord-api-types": "^0.38.44",
    "discord-interactions": "^4.4.0",
    "drizzle-orm": "1.0.0-beta.20",
    "next": "^16.2.2",
    "open-graph-scraper": "^6.11.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-fast-marquee": "^1.6.5",
    "react-icons": "^5.6.0",
    "react-image-crop": "^11.0.10",
    "zod": "4.1.8",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/env": "^16.2.2",
    "@supabase/auth-js": "^2.101.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "1.0.0-beta.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "raw-loader": "^4.0.2",
    "supabase": "^2.84.7",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vercel": "^50.38.3"
  },
  "packageManager": "pnpm@10.28.1"
}
